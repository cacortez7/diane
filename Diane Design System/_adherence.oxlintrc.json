{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/**",
              "components/core/**",
              "components/forms/**",
              "components/pipeline/**",
              "ui_kits/diane-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Mono|IBM Plex Sans))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Mono, IBM Plex Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|dot|pulse|outline|uppercase|className|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, dot, pulse, outline, uppercase, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|green|cyan|amber|red|violet|blue)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'green' | 'cyan' | 'amber' | 'red' | 'violet' | 'blue'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|block|loading|disabled|leadingIcon|trailingIcon|type|className|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, block, loading, disabled, leadingIcon, trailingIcon, type, className, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|title|terminalDots|actions|flushBody|shadow|className|bodyClassName|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, title, terminalDots, actions, flushBody, shadow, className, bodyClassName."
      },
      {
        "selector": "JSXOpeningElement[name.name='RadioCardOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|description|badge|disabled|key|ref|className|style|children)$/]",
        "message": "<RadioCardOption> doesn't accept that prop. Declared props: value, label, description, badge, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|disabled|key|ref|className|style|children)$/]",
        "message": "<SegmentedOption> doesn't accept that prop. Declared props: value, label, icon, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StageStep'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|status|device|index|detail|duration|className|key|ref|className|style|children)$/]",
        "message": "<StageStep> doesn't accept that prop. Declared props: name, status, device, index, detail, duration, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='StageStep'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:pending|running|done|error|cached)$/]",
        "message": "<StageStep> status must be one of 'pending' | 'running' | 'done' | 'error' | 'cached'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StageStep'] > JSXAttribute[name.name='device'] > Literal[value!=/^(?:GPU|CPU)$/]",
        "message": "<StageStep> device must be one of 'GPU' | 'CPU'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TerminalLine'] > JSXAttribute > JSXIdentifier[name!=/^(?:msg|level|ts|key|ref|className|style|children)$/]",
        "message": "<TerminalLine> doesn't accept that prop. Declared props: msg, level, ts."
      },
      {
        "selector": "JSXOpeningElement[name.name='TerminalLine'] > JSXAttribute[name.name='level'] > Literal[value!=/^(?:info|success|warn|error|debug|stage)$/]",
        "message": "<TerminalLine> level must be one of 'info' | 'success' | 'warn' | 'error' | 'debug' | 'stage'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|onChange|placeholder|multiline|rows|prefix|type|required|disabled|error|help|id|className|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: label, value, onChange, placeholder, multiline, rows, prefix, type, required, disabled, error, help, id, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|disabled|id|className|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: checked, onChange, label, disabled, id, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='VramMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:used|total|label|unit|className|key|ref|className|style|children)$/]",
        "message": "<VramMeter> doesn't accept that prop. Declared props: used, total, label, unit, className."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
